  "item": [
    {
      "name": "Auth - Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "/****************************************************************************/",
              "pm.test(\"El campo 'success' es 'true'\", function () {",
              "    let jsonData = pm.response.json();",
              "    pm.collectionVariables.set(\"jwtToken\", jsonData.data);",
              "    pm.expect(jsonData.success).to.eql(true);",
              "});",
              "/****************************************************************************/",
              "// Schema validation",
              "const schema = {",
              "  type: 'object',",
              "  properties: {",
              "    success: { type: 'boolean' },",
              "    message: { type: 'string' },",
              "    data: { type: 'string' },",
              "    errors: { type: 'array' }",
              "  },",
              "  required: ['success', 'message', 'data', 'errors']",
              "};",
              "pm.test(\"Response matches schema\", function () {",
              "  pm.response.to.have.jsonSchema(schema);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"administrador\",\n  \"password\": \"Default.123@\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/Auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "Auth",
            "login"
          ]
        }
      },
      "response": []
    },
